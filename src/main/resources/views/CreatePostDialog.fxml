<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!--
    Load this in HomeController via:
        FXMLLoader loader = new FXMLLoader(getClass().getResource("/fxml/CreatePostDialog.fxml"));
        Parent root = loader.load();
        Stage dialog = new Stage();
        dialog.initModality(Modality.APPLICATION_MODAL);
        dialog.initStyle(StageStyle.UNDECORATED);   // frameless for custom chrome
        dialog.setScene(new Scene(root));
        dialog.showAndWait();
-->
<VBox styleClass="dialog-root" spacing="0"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.controller.CreatePostController"
      style="-fx-background-color: white;
             -fx-background-radius: 16;
             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.22), 32, 0, 0, 8);"
      prefWidth="600">

    <!-- ── HEADER ── -->
    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="dialog-header">
        <padding><Insets top="20" right="20" bottom="16" left="20" /></padding>
        <!-- Avatar -->
        <Label text="👤" style="-fx-font-size: 38px; -fx-text-fill: #475569;" />
        <!-- Title block -->
        <VBox spacing="2" HBox.hgrow="ALWAYS">
            <Label text="Créer une publication" styleClass="dialog-title" />
            <Label fx:id="dialogSubtitle" text="VitaHealth Community Feed"
                   styleClass="dialog-subtitle" />
        </VBox>
        <!-- Close button -->
        <Button text="✕" onAction="#closeDialog" styleClass="dialog-close-btn" />
    </HBox>

    <Separator style="-fx-background-color: #e2e8f0;" />

    <!-- ── BODY ── -->
    <VBox spacing="18" style="-fx-padding: 24 24 16 24;">

        <!-- Row 1: Headline + Category -->
        <HBox spacing="16">
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="TITRE DE LA PUBLICATION" styleClass="dialog-field-label" />
                <TextField fx:id="titreField"
                           promptText="Entrez un titre descriptif..."
                           styleClass="dialog-input" />
            </VBox>
            <VBox spacing="6">
                <Label text="CATÉGORIE MÉDICALE" styleClass="dialog-field-label" />
                <ComboBox fx:id="categorieCombo"
                          promptText="Sélectionner..."
                          prefWidth="200"
                          styleClass="dialog-combo" />
            </VBox>
        </HBox>

        <!-- Row 2: Content area -->
        <VBox spacing="6">
            <HBox alignment="CENTER_LEFT">
                <Label text="CONTENU" styleClass="dialog-field-label" HBox.hgrow="ALWAYS" />
                <Label text="Aide IA" styleClass="dialog-ai-badge" />
            </HBox>

            <!-- Toolbar row (formatting hint — visual only; wire in controller if needed) -->
            <HBox styleClass="editor-toolbar" spacing="4" alignment="CENTER_LEFT">
                <padding><Insets top="6" right="8" bottom="6" left="8" /></padding>
                <Button text="B" styleClass="toolbar-btn" style="-fx-font-weight: bold;" />
                <Button text="I" styleClass="toolbar-btn" style="-fx-font-style: italic;" />
                <Button text="U" styleClass="toolbar-btn" style="-fx-underline: true;" />
                <Separator orientation="VERTICAL" style="-fx-padding: 0 4;" />
                <Button text="≡" styleClass="toolbar-btn" />
                <Button text="⁞≡" styleClass="toolbar-btn" />
                <Separator orientation="VERTICAL" style="-fx-padding: 0 4;" />
                <Button text="🔗" styleClass="toolbar-btn" />
                <Button text="❝" styleClass="toolbar-btn" />
            </HBox>

            <TextArea fx:id="contenuField"
                      promptText="Partagez vos observations cliniques, résumés d'études de cas ou questions basées sur des preuves avec la communauté médicale..."
                      prefRowCount="5"
                      wrapText="true"
                      styleClass="dialog-textarea" />
        </VBox>

        <!-- Row 3: Supporting materials placeholder -->
        <VBox spacing="6">
            <Label text="PIÈCES JOINTES" styleClass="dialog-field-label" />
            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-background-color: #f8fafc;
                         -fx-border-color: #e2e8f0;
                         -fx-border-width: 1;
                         -fx-border-radius: 8;
                         -fx-background-radius: 8;
                         -fx-padding: 12 16;">
                <Label text="📎" style="-fx-font-size: 18px;" />
                <Label text="Glissez des fichiers ici ou cliquez pour joindre"
                       style="-fx-text-fill: #94a3b8; -fx-font-size: 13px;" />
            </HBox>
        </VBox>

    </VBox>

    <Separator style="-fx-background-color: #e2e8f0;" />

    <!-- ── FOOTER ── -->
    <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 16 24;">
        <!-- Compliance badge -->
        <Label text="⚡  CONTRÔLE DE CONFORMITÉ ACTIF"
               styleClass="compliance-badge" />

        <!-- Spacer -->
        <Region HBox.hgrow="ALWAYS" />

        <!-- Action buttons -->
        <Button text="Enregistrer en brouillon" onAction="#saveDraft"
                styleClass="btn-secondary" />
        <Button text="PUBLIER" onAction="#publish"
                styleClass="btn-primary" />
    </HBox>

</VBox>
