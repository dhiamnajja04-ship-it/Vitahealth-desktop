<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane stylesheets="/css/style.css"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controller.ForumController"
            style="-fx-background-color: #f0f4f8;">

    <!-- ── TOP BAR ── -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: white;
                     -fx-border-color: #e2e8f0;
                     -fx-border-width: 0 0 1 0;
                     -fx-padding: 12 24;">
            <Label text="📋 Forum de la communauté"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" />
            <Region HBox.hgrow="ALWAYS" />
            <TextField fx:id="searchField" promptText="🔍 Rechercher un sujet..."
                       prefWidth="260" styleClass="search-input" />
            <Button text="Rechercher" onAction="#rechercher" styleClass="btn-primary"
                    style="-fx-padding: 9 20;" />
        </HBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.58"
                   style="-fx-background-color: #f0f4f8; -fx-padding: 0;">

            <!-- ══════════ LEFT PANEL : Topics ══════════ -->
            <VBox spacing="16" style="-fx-background-color: #f0f4f8; -fx-padding: 20 16 20 20;">

                <!-- Create / Edit form card -->
                <VBox styleClass="post-card" spacing="16">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="✏️" style="-fx-font-size: 20px;" />
                        <Label text="Nouveau sujet / Modifier"
                               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" />
                    </HBox>
                    <Separator />

                    <!-- Title -->
                    <VBox spacing="5">
                        <Label text="TITRE" styleClass="dialog-field-label" />
                        <TextField fx:id="titreField" promptText="Titre du sujet"
                                   styleClass="dialog-input" />
                    </VBox>

                    <!-- Category -->
                    <VBox spacing="5">
                        <Label text="CATÉGORIE" styleClass="dialog-field-label" />
                        <ComboBox fx:id="categorieCombo" maxWidth="Infinity"
                                  styleClass="dialog-combo" />
                    </VBox>

                    <!-- Content -->
                    <VBox spacing="5">
                        <Label text="CONTENU" styleClass="dialog-field-label" />
                        <TextArea fx:id="contenuArea"
                                  promptText="Décrivez votre sujet clinique..."
                                  prefRowCount="4" wrapText="true"
                                  styleClass="dialog-textarea" />
                    </VBox>

                    <!-- Buttons -->
                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Button text="🔄 Effacer"     onAction="#effacer"        styleClass="btn-secondary" />
                        <Button text="🗑️ Supprimer"   onAction="#supprimerSujet"  styleClass="btn-delete" />
                        <Button text="✏️ Modifier"    onAction="#modifierSujet"   styleClass="btn-warning" />
                        <Button text="➕ Ajouter"     onAction="#ajouterSujet"    styleClass="btn-primary" />
                    </HBox>
                </VBox>

                <!-- Topic list -->
                <VBox spacing="8" VBox.vgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label text="Liste des Sujets"
                               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button text="✅ Valider"   onAction="#validerSujet"
                                styleClass="btn-success" style="-fx-padding: 7 16;" />
                        <Button text="❌ Invalider" onAction="#invaliderSujet"
                                styleClass="btn-delete"  style="-fx-padding: 7 16;" />
                    </HBox>

                    <TableView fx:id="sujetTable" VBox.vgrow="ALWAYS"
                               onMouseClicked="#selectionnerSujet"
                               styleClass="modern-table">
                        <columns>
                            <TableColumn fx:id="colTitre"     text="TITRE"      prefWidth="160" />
                            <TableColumn fx:id="colCategorie" text="CATÉGORIE"  prefWidth="100" />
                            <TableColumn fx:id="colAuteur"    text="AUTEUR"     prefWidth="90" />
                            <TableColumn fx:id="colValid"     text="VALIDÉ"     prefWidth="60" />
                            <TableColumn fx:id="colDate"      text="DATE"       prefWidth="130" />
                        </columns>
                        <placeholder><Label text="Aucun sujet trouvé" style="-fx-text-fill: #94a3b8;" /></placeholder>
                    </TableView>
                </VBox>
            </VBox>

            <!-- ══════════ RIGHT PANEL : Comments ══════════ -->
            <VBox spacing="16" style="-fx-background-color: #f0f4f8; -fx-padding: 20 20 20 12;">

                <!-- Selected topic header -->
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="post-card"
                      style="-fx-padding: 14 16;">
                    <Label text="💬" style="-fx-font-size: 18px;" />
                    <Label fx:id="sujetSelectionneLabel"
                           text="Sélectionnez un sujet pour afficher les commentaires"
                           style="-fx-font-size: 13px; -fx-text-fill: #64748b;" />
                </HBox>

                <!-- Comments table -->
                <TableView fx:id="commentaireTable" VBox.vgrow="ALWAYS"
                           styleClass="modern-table">
                    <columns>
                        <TableColumn fx:id="colComAuteur"  text="AUTEUR"       prefWidth="110" />
                        <TableColumn fx:id="colComContenu" text="COMMENTAIRE"  prefWidth="230" />
                        <TableColumn fx:id="colComDate"    text="DATE"         prefWidth="120" />
                    </columns>
                    <placeholder><Label text="Aucun commentaire" style="-fx-text-fill: #94a3b8;" /></placeholder>
                </TableView>

                <!-- Add comment card -->
                <VBox styleClass="post-card" spacing="12">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="💬" style="-fx-font-size: 18px;" />
                        <Label text="Ajouter un commentaire"
                               style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" />
                    </HBox>
                    <Separator />
                    <TextArea fx:id="comContenuArea"
                              promptText="Votre commentaire clinique..."
                              prefRowCount="3" wrapText="true"
                              styleClass="dialog-textarea" />
                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Label fx:id="nbCommentairesLabel" text=""
                               style="-fx-text-fill: #94a3b8; -fx-font-size: 12px;"
                               HBox.hgrow="ALWAYS" />
                        <Button text="🗑️ Supprimer" onAction="#supprimerCommentaire"
                                styleClass="btn-delete" style="-fx-padding: 8 16;" />
                        <Button text="Envoyer 📨" onAction="#ajouterCommentaire"
                                styleClass="btn-primary" style="-fx-padding: 8 20;" />
                    </HBox>
                </VBox>

            </VBox>
        </SplitPane>
    </center>

    <!-- ── STATUS BAR ── -->
    <bottom>
        <HBox styleClass="statusbar" alignment="CENTER_LEFT" style="-fx-padding: 0 16;">
            <Label fx:id="statusLabel" text="✅ Prêt" styleClass="status-text" />
        </HBox>
    </bottom>

</BorderPane>
