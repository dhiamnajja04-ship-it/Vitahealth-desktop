<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="800" prefWidth="1280"
            stylesheets="/css/style.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controller.MainController">

    <!-- ════════════════ TOP NAVBAR ════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="60" styleClass="navbar" spacing="0">

            <!-- Logo block -->
            <HBox alignment="CENTER_LEFT" prefWidth="252" spacing="0"
                  style="-fx-padding: 0 16 0 20;
                         -fx-border-color: transparent #e2e8f0 transparent transparent;
                         -fx-border-width: 0 1 0 0;">
                <VBox alignment="CENTER_LEFT" spacing="0">
                    <Label styleClass="logo-text" text="VitaHealth" />
                    <Label text="CLINICAL SANCTUARY"
                           style="-fx-font-size: 9px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: #94a3b8;
                                  -fx-letter-spacing: 0.1em;" />
                </VBox>
            </HBox>

            <!-- Search bar (centered) -->
            <HBox alignment="CENTER" HBox.hgrow="ALWAYS" style="-fx-padding: 0 24;">
                <TextField fx:id="searchField"
                           prefWidth="340"
                           promptText="🔍  Rechercher des insights cliniques, experts ou publications..."
                           styleClass="search-input"
                           onAction="#handleSearch" />
            </HBox>

            <!-- Right actions -->
            <HBox alignment="CENTER" spacing="4" style="-fx-padding: 0 16 0 0;">
                <Button fx:id="btnHome"   onAction="#showHome"   styleClass="nav-btn,nav-btn-active" text="🏠 Accueil" />
                <Button fx:id="btnForum"  onAction="#showForum"  styleClass="nav-btn"                text="📋 Forum" />
                <Button fx:id="btnAdmin"  onAction="#showAdmin"  styleClass="nav-btn"                text="⚙️ Admin" />

                <!-- Divider -->
                <Separator orientation="VERTICAL" style="-fx-padding: 8 6;" />

                <!-- Notification bell -->
                <Button text="🔔" styleClass="icon-nav-btn" />
                <!-- Messages -->
                <Button text="💬" styleClass="icon-nav-btn" />

                <!-- User chip -->
                <HBox alignment="CENTER" spacing="8" styleClass="user-chip">
                    <Label text="👤" style="-fx-font-size: 22px;" />
                    <VBox spacing="0">
                        <Label fx:id="navUsernameLabel" text="Dr. Utilisateur"
                               style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #0f172a;" />
                        <Label fx:id="navRoleLabel" text="Clinicien"
                               style="-fx-font-size: 10px; -fx-text-fill: #94a3b8;" />
                    </VBox>
                </HBox>
            </HBox>

        </HBox>
    </top>

    <!-- ════════════════ CENTER LAYOUT ════════════════ -->
    <center>
        <HBox>

            <!-- ── LEFT SIDEBAR ── -->
            <ScrollPane fitToWidth="true" prefWidth="252" styleClass="sidebar-scroll">
                <VBox spacing="2" styleClass="sidebar-left">
                    <padding><Insets bottom="12" left="8" right="8" top="12" /></padding>

                    <!-- User profile block -->
                    <HBox alignment="CENTER_LEFT" spacing="10" styleClass="sidebar-profile">
                        <Label style="-fx-font-size: 34px;" text="👤" />
                        <VBox spacing="2">
                            <Label fx:id="usernameLabel" styleClass="sidebar-username" text="Utilisateur" />
                            <Label fx:id="roleLabel"     styleClass="sidebar-subtitle"  text="Rôle" />
                        </VBox>
                    </HBox>

                    <!-- Main nav -->
                    <Button alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#showHome"
                            styleClass="sidebar-item,sidebar-active" text="🏠  Accueil" />
                    <Button alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#showForum"
                            styleClass="sidebar-item" text="💬  Forum" />
                    <Button alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#showAdmin"
                            styleClass="sidebar-item" text="⚙️  Administration" />

                    <Separator style="-fx-padding: 4 0;" />

                    <!-- Categories section -->
                    <Label styleClass="sidebar-section-title" text="CATÉGORIES" />
                    <Button alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#filterByNutrition"
                            styleClass="sidebar-item" text="🍎  Nutrition" />
                    <Button alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#filterByCardio"
                            styleClass="sidebar-item" text="❤️  Cardiologie" />
                    <Button alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#filterByPsycho"
                            styleClass="sidebar-item" text="🧠  Psychologie" />
                    <Button alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#filterByPediatrie"
                            styleClass="sidebar-item" text="👶  Pédiatrie" />
                    <Button alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#showAllSubjects"
                            styleClass="sidebar-item" text="📂  Tous les sujets" />

                    <!-- Spacer pushes logout to bottom -->
                    <Region VBox.vgrow="ALWAYS" />

                    <Separator style="-fx-padding: 4 0;" />

                    <!-- New post CTA -->
                    <Button alignment="CENTER" maxWidth="Infinity"
                            styleClass="sidebar-new-btn" text="➕  Nouvelle publication"
                            onAction="#openCreateModal" />

                    <!-- Logout -->
                    <Button alignment="CENTER_LEFT" maxWidth="Infinity" onAction="#logout"
                            styleClass="sidebar-logout" text="🚪  Déconnexion" />

                </VBox>
            </ScrollPane>

            <!-- ── CENTRAL CONTENT AREA ── -->
            <StackPane fx:id="contentArea" prefWidth="760" styleClass="content-area"
                       HBox.hgrow="ALWAYS" />

            <!-- ── RIGHT SIDEBAR ── -->
            <ScrollPane fitToWidth="true" prefWidth="290" styleClass="sidebar-scroll"
                        style="-fx-background-color: #f8fafc;">
                <VBox spacing="14" styleClass="sidebar-right">
                    <padding><Insets bottom="16" left="12" right="12" top="16" /></padding>

                    <!-- Trends widget -->
                    <VBox spacing="8" styleClass="widget-card">
                        <Label styleClass="widget-title" text="🔥  Tendances" />
                        <Separator />
                        <Label styleClass="trend-item" text="#Hypertension  ·  42 posts" />
                        <Label styleClass="trend-item" text="#Nutrition  ·  38 posts" />
                        <Label styleClass="trend-item" text="#Sommeil  ·  29 posts" />
                    </VBox>

                    <!-- Active members widget -->
                    <VBox spacing="10" styleClass="widget-card">
                        <Label styleClass="widget-title" text="👥  Membres actifs" />
                        <Separator />
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label style="-fx-font-size: 28px;" text="👤" />
                            <VBox spacing="1">
                                <Label styleClass="member-name" text="Dr. Ben Ali" />
                                <Label styleClass="member-sub" text="Médecin  ·  120 posts" />
                            </VBox>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label style="-fx-font-size: 28px;" text="👤" />
                            <VBox spacing="1">
                                <Label styleClass="member-name" text="Sami Ouali" />
                                <Label styleClass="member-sub" text="Patient  ·  87 posts" />
                            </VBox>
                        </HBox>
                    </VBox>

                    <!-- Stats widget -->
                    <VBox spacing="10" styleClass="widget-card">
                        <Label styleClass="widget-title" text="📊  Statistiques" />
                        <Separator />
                        <HBox alignment="CENTER" spacing="24">
                            <VBox alignment="CENTER" spacing="2">
                                <Label fx:id="totalSujetsLabel" styleClass="stat-number" text="0" />
                                <Label styleClass="stat-label" text="Sujets" />
                            </VBox>
                            <VBox alignment="CENTER" spacing="2">
                                <Label fx:id="totalComLabel" styleClass="stat-number" text="0" />
                                <Label styleClass="stat-label" text="Commentaires" />
                            </VBox>
                        </HBox>
                    </VBox>

                </VBox>
            </ScrollPane>
        </HBox>
    </center>

    <!-- ════════════════ STATUS BAR ════════════════ -->
    <bottom>
        <HBox alignment="CENTER_LEFT" prefHeight="28" spacing="16" styleClass="statusbar">
            <padding><Insets left="16" right="16" /></padding>
            <Label fx:id="statusLabel" styleClass="status-text" text="✅ Bienvenue sur VitaHealth" />
        </HBox>
    </bottom>

</BorderPane>
